{
	"info": {
		"_postman_id": "justwoo-kmp-api-collection-v3",
		"name": "JustWoo API",
		"description": "JustWoo KMP backend — fully RESTful collection.\n\nBase URL: http://localhost:8000\nAuth: JWT Bearer Token\n\nOnboarding flow:\n  1. Register  →  auto-saves accessToken + userId\n  2. Create Profile\n  3. Login (when token expires)\n  4. Create House  →  auto-saves houseId\n  5. Create Task   →  auto-saves taskId",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl",      "value": "http://localhost:8000", "type": "string" },
		{ "key": "accessToken",  "value": "", "type": "string" },
		{ "key": "refreshToken", "value": "", "type": "string" },
		{ "key": "userId",       "value": "", "type": "string" },
		{ "key": "houseId",      "value": "1", "type": "string" },
		{ "key": "taskId",       "value": "1", "type": "string" },
		{ "key": "memberId",     "value": "1", "type": "string" }
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Hello",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/hello",
							"host": ["{{baseUrl}}"],
							"path": ["hello"]
						},
						"description": "Health check. Returns: 你好，JustWoo 後端已就緒！"
					},
					"response": []
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    var d = pm.response.json();",
									"    pm.collectionVariables.set('accessToken', d.accessToken);",
									"    pm.collectionVariables.set('refreshToken', d.token.refreshToken);",
									"    pm.collectionVariables.set('userId', d.user.id.toString());",
									"    console.log('Saved! userId=' + d.user.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\",\n    \"plainPassword\": \"password123\",\n    \"deviceId\": \"postman-device-001\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						},
						"description": "Register a new user. Auto-saves accessToken, refreshToken, userId."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var d = pm.response.json();",
									"    pm.collectionVariables.set('accessToken', d.accessToken);",
									"    pm.collectionVariables.set('refreshToken', d.token.refreshToken);",
									"    pm.collectionVariables.set('userId', d.user.id.toString());",
									"    console.log('Saved! userId=' + d.user.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\",\n    \"deviceId\": \"postman-device-001\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						},
						"description": "Login. Auto-saves accessToken, refreshToken, userId.\n429 after 10 failed attempts within 24 hours."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var d = pm.response.json();",
									"    pm.collectionVariables.set('refreshToken', d.refreshToken);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"deviceId\": \"postman-device-001\",\n    \"token\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "refresh"]
						},
						"description": "Exchange a refresh token for a new refresh token."
					},
					"response": []
				}
			]
		},
		{
			"name": "Profiles",
			"item": [
				{
					"name": "Create Profile",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"My Name\",\n    \"avatar\": \"https://example.com/avatar.png\",\n    \"bankAccount\": \"123-456-789\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/profiles",
							"host": ["{{baseUrl}}"],
							"path": ["profiles"]
						},
						"description": "Create a profile for the authenticated user.\nIdentity comes from the JWT — no need to pass userId in the URL.\n\nWas: POST /profiles/me"
					},
					"response": []
				},
				{
					"name": "Get My Profile",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": {
							"raw": "{{baseUrl}}/profiles/me",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "me"]
						},
						"description": "Get the profile of the currently authenticated user."
					},
					"response": []
				},
				{
					"name": "Update My Profile",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Name\",\n    \"avatar\": \"https://example.com/new-avatar.png\",\n    \"bankAccount\": \"987-654-321\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/profiles/me",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "me"]
						},
						"description": "Update the profile of the currently authenticated user."
					},
					"response": []
				},
				{
					"name": "Get Profile by User ID",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": {
							"raw": "{{baseUrl}}/profiles/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["profiles", "{{userId}}"]
						},
						"description": "Get the profile of any user by their ID."
					},
					"response": []
				}
			]
		},
		{
			"name": "Houses",
			"item": [
				{
					"name": "Get All Houses",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": {
							"raw": "{{baseUrl}}/houses",
							"host": ["{{baseUrl}}"],
							"path": ["houses"]
						},
						"description": "Get all houses the authenticated user belongs to."
					},
					"response": []
				},
				{
					"name": "Create House",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var d = pm.response.json();",
									"    pm.collectionVariables.set('houseId', d.id.toString());",
									"    console.log('houseId saved: ' + d.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"My House\",\n    \"name\": \"home-sweet-home\",\n    \"adminUserId\": {{userId}},\n    \"memberIds\": [{{userId}}],\n    \"description\": \"Our shared house\",\n    \"createTime\": \"2026-04-17T00:00:00Z\",\n    \"updateTime\": \"2026-04-17T00:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/houses",
							"host": ["{{baseUrl}}"],
							"path": ["houses"]
						},
						"description": "Create a new house. Auto-saves houseId."
					},
					"response": []
				},
				{
					"name": "Get House by ID",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": {
							"raw": "{{baseUrl}}/houses/{{houseId}}",
							"host": ["{{baseUrl}}"],
							"path": ["houses", "{{houseId}}"]
						},
						"description": "Get a specific house. User must be a member."
					},
					"response": []
				},
				{
					"name": "Update House",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Updated Title\",\n    \"name\": \"updated-name\",\n    \"adminUserId\": {{userId}},\n    \"memberIds\": [{{userId}}],\n    \"description\": \"Updated description\",\n    \"createTime\": \"2026-04-17T00:00:00Z\",\n    \"updateTime\": \"2026-04-17T12:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/houses/{{houseId}}",
							"host": ["{{baseUrl}}"],
							"path": ["houses", "{{houseId}}"]
						},
						"description": "Update house details. User must be a member/admin."
					},
					"response": []
				},
				{
					"name": "Add Member",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": {
							"raw": "{{baseUrl}}/houses/{{houseId}}/members/{{memberId}}",
							"host": ["{{baseUrl}}"],
							"path": ["houses", "{{houseId}}", "members", "{{memberId}}"]
						},
						"description": "Add a member to a house.\n\nChanged POST → PUT: adding a member is idempotent — calling it twice produces the same result, so PUT is semantically correct."
					},
					"response": []
				},
				{
					"name": "Remove Member",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": {
							"raw": "{{baseUrl}}/houses/{{houseId}}/members/{{memberId}}",
							"host": ["{{baseUrl}}"],
							"path": ["houses", "{{houseId}}", "members", "{{memberId}}"]
						},
						"description": "Remove a member from a house."
					},
					"response": []
				}
			]
		},
		{
			"name": "Tasks",
			"item": [
				{
					"name": "Get Tasks",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": {
							"raw": "{{baseUrl}}/houses/{{houseId}}/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["houses", "{{houseId}}", "tasks"]
						},
						"description": "Get all tasks in a house."
					},
					"response": []
				},
				{
					"name": "Get Tasks by Owner",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": {
							"raw": "{{baseUrl}}/houses/{{houseId}}/tasks?ownerId={{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["houses", "{{houseId}}", "tasks"],
							"query": [
								{ "key": "ownerId", "value": "{{userId}}" }
							]
						},
						"description": "Filter tasks by owner. Uses query param on the same /tasks endpoint."
					},
					"response": []
				},
				{
					"name": "Get Tasks by Assignee",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": {
							"raw": "{{baseUrl}}/houses/{{houseId}}/tasks?assigneeId={{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["houses", "{{houseId}}", "tasks"],
							"query": [
								{ "key": "assigneeId", "value": "{{userId}}" }
							]
						},
						"description": "Filter tasks by assignee. Uses query param on the same /tasks endpoint."
					},
					"response": []
				},
				{
					"name": "Create Task",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    var d = pm.response.json();",
									"    pm.collectionVariables.set('taskId', d.id.toString());",
									"    console.log('taskId saved: ' + d.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Clean the kitchen\",\n    \"ownerId\": {{userId}},\n    \"description\": \"Deep clean including oven and fridge\",\n    \"houseId\": {{houseId}},\n    \"accessLevel\": \"PUBLIC\",\n    \"assigneeIds\": [{{userId}}],\n    \"dueTime\": \"2026-04-20T18:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/houses/{{houseId}}/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["houses", "{{houseId}}", "tasks"]
						},
						"description": "Create a task. Auto-saves taskId.\naccessLevel: PRIVATE | PUBLIC"
					},
					"response": []
				},
				{
					"name": "Update Task",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"id\": {{taskId}},\n    \"title\": \"Updated title\",\n    \"description\": \"Updated description\",\n    \"status\": \"IN_PROGRESS\",\n    \"accessLevel\": \"PUBLIC\",\n    \"ownerId\": {{userId}},\n    \"houseId\": {{houseId}},\n    \"dueTime\": \"2026-04-21T18:00:00Z\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/houses/{{houseId}}/tasks/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["houses", "{{houseId}}", "tasks", "{{taskId}}"]
						},
						"description": "Update task content. Only the task owner can call this.\nstatus: TODO | IN_PROGRESS | DONE\naccessLevel: PRIVATE | PUBLIC"
					},
					"response": []
				},
				{
					"name": "Update Task Status",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "\"DONE\""
						},
						"url": {
							"raw": "{{baseUrl}}/houses/{{houseId}}/tasks/{{taskId}}/status",
							"host": ["{{baseUrl}}"],
							"path": ["houses", "{{houseId}}", "tasks", "{{taskId}}", "status"]
						},
						"description": "Update the overall task status. Only the task executor can call this.\nValues: \"TODO\" | \"IN_PROGRESS\" | \"DONE\""
					},
					"response": []
				},
				{
					"name": "Update Assignee Status",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "\"ACCEPTED\""
						},
						"url": {
							"raw": "{{baseUrl}}/houses/{{houseId}}/tasks/{{taskId}}/assignees/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["houses", "{{houseId}}", "tasks", "{{taskId}}", "assignees", "{{userId}}"]
						},
						"description": "Update the assignment status for a specific assignee.\nOnly the assignee themselves can call this.\n\nChanged from PATCH /tasks/{taskId}/assign-status with userId in body\n→ PATCH /tasks/{taskId}/assignees/{userId} with status in body.\nassignees/{userId} treats the assignee as a proper sub-resource.\n\nValues: \"UNASSIGNED\" | \"PENDING_APPROVAL\" | \"ACCEPTED\" | \"REJECTED\" | \"COMPLETED\""
					},
					"response": []
				}
			]
		}
	]
}
